# ── Server ────────────────────────────────────────────────────────────────────
# Static Bearer API key for local / dev / stdio usage.
# Leave unset if you are using OAuth exclusively.
MCP_SERVER_API_KEY=

# Transport: "stdio" (default, local) or "http" (remote/Render deployment)
MCP_TRANSPORT=stdio

# Port used when MCP_TRANSPORT=http
PORT=8000

# ── OAuth 2.0 (ChatGPT connector and OAuth-compatible clients) ─────────────────
# Set OAUTH_CLIENT_ID to enable the OAuth flow.
# Both OAuth and MCP_SERVER_API_KEY can be active simultaneously.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
# Comma-separated list of allowed redirect URIs registered with the OAuth client.
OAUTH_REDIRECT_URIS=
# Space-separated scopes advertised and accepted (default: mcp).
OAUTH_SCOPES=mcp
# Access token lifetime in seconds (default: 3600).
OAUTH_TOKEN_TTL_SECONDS=3600

# ── Redis (OAuth token persistence) ───────────────────────────────────────────
# When set, OAuth auth codes and access tokens are stored in Redis instead of
# in-memory. Tokens survive redeploys and work across multiple instances.
# On Render: provision a Redis instance and paste the Internal Redis URL here.
# Leave unset for local / stdio / test usage (falls back to in-memory).
REDIS_URL=

# ── Safety gates ──────────────────────────────────────────────────────────────
MCP_READ_ONLY=true
MCP_REQUIRE_CONFIRMATION=true
MCP_ALLOWED_REPOS=vinicius-ssantos/github-unified-mcp,vinicius-ssantos/deploy-orchestrator-mcp
MCP_ALLOWED_ENVIRONMENTS=preview,staging
MCP_ALLOWED_PROVIDERS=render,railway,supabase

# ── Provider credentials ───────────────────────────────────────────────────────
# These can also be set at runtime via the credentials_set MCP tool.
RENDER_API_KEY=
RAILWAY_TOKEN=
FLY_API_TOKEN=
KOYEB_API_TOKEN=
COOLIFY_BASE_URL=
COOLIFY_API_TOKEN=
SUPABASE_ACCESS_TOKEN=
SUPABASE_ORG_ID=
